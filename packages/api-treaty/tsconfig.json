{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    // INFO: disabled these for enabling import typings on my web app
    // package :(
    // "allowImportingTsExtensions": true,
    // "noEmit": true,
    "verbatimModuleSyntax": true,
    "declaration": true,
    "declarationMap": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,

    "composite": true,
    // @ts-ignore this is required for path mapping
    "baseUrl": ".",
    "paths": {
      "@qeberodev/api": ["../../apps/api/src"],
    },
  },
  "references": [
    {
      "path": "../../apps/api",
    },
  ],
}
