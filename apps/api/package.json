{
  "name": "@qeberodev/api",
  "types": "./dist/src/index.d.ts",
  "main": "./dist/index.js",
  "type": "module",
  "version": "1.0.50",
  "scripts": {
    "build": "bun ./scripts/build.ts",
    "dev": "bun ./scripts/dev.ts",
    "test:http": "hurl --variable host=http://localhost:3000 --test ./tests/http",
    "db:info": "echo 'db:* for database related actions'",
    "db:generate": "bun --bun drizzle-kit generate",
    "db:pull": "bun --bun drizzle-kit pull",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:seed": "bun run src/db/seed.ts",
    "db:clean": "rm -rf data/app.db drizzle/",
    "auth:generate-schema": "bun --bun x @better-auth/cli generate --output src/db/schema/auth.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@loglayer/transport-simple-pretty-terminal": "^3.0.2",
    "@qeberodev/schema": "workspace:*",
    "better-auth": "catalog:",
    "date-fns": "catalog:",
    "drizzle-orm": "^0.45.1",
    "drizzle-typebox": "^0.3.3",
    "drizzle-zod": "^0.8.3",
    "effect": "^3.19.19",
    "elysia": "catalog:",
    "loglayer": "catalog:",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@orangeopensource/hurl": "^7.1.3",
    "@types/better-sqlite3": "^7.6.13",
    "bun-types": "latest",
    "concurrently": "catalog:",
    "drizzle-kit": "^0.31.9"
  },
  "trustedDependencies": [
    "@orangeopensource/hurl",
    "better-sqlite3",
    "esbuild"
  ],
  "overrides": {
    "@sinclair/typebox": ">= 0.34.0 < 1"
  }
}
