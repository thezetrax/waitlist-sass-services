{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
    },
    "types": ["bun-types"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "composite": true,

    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
  },
  "exclude": ["node_modules", "dist", "script", "cmd"],
}
